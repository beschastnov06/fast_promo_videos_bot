BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
ALLOWED_TELEGRAM_USERNAMES=
TMP_DIR=/app/tmp
MAX_CONCURRENT_RENDERS=1
RENDER_JOB_TIMEOUT_SECONDS=900

# Production infrastructure.
# Railway injects DATABASE_URL and REDIS_URL when PostgreSQL and Redis are connected.
# Local docker-compose values:
# DATABASE_URL=postgresql+asyncpg://video_bot:video_bot@postgres:5432/video_bot
# REDIS_URL=redis://redis:6379/0

# Optional. Use a local Telegram Bot API server for larger files.
# TELEGRAM_API_BASE=http://telegram-bot-api:8081
# TELEGRAM_API_IS_LOCAL=true
