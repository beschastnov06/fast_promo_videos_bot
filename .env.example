BOT_TOKEN=your_telegram_bot_token_here
ADMIN_BOT_TOKEN=your_admin_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
RESTRICT_TELEGRAM_USERS=false
ALLOWED_TELEGRAM_USERNAMES=
ADMINS_USERNAME=
TMP_DIR=/app/tmp
MAX_CONCURRENT_RENDERS=1
RENDER_JOB_TIMEOUT_SECONDS=900
TELEGRAM_REQUEST_TIMEOUT_SECONDS=600
PUBLIC_BASE_URL=https://example.com

# Robokassa.
ROBOKASSA_MERCHANT_LOGIN=@fast_promo_videos_bot
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_PASSWORD1=
ROBOKASSA_TEST_PASSWORD2=
ROBOKASSA_TEST_MODE=false
ROBOKASSA_HASH_ALGORITHM=md5
ROBOKASSA_OFFER_URL=https://telegra.ph/Oferta-usloviya-okazaniya-uslug-i-politika-obrabotki-personalnyh-dannyh-05-07

# Production infrastructure.
# Railway injects DATABASE_URL and REDIS_URL when PostgreSQL and Redis are connected.
# Local docker-compose values:
# DATABASE_URL=postgresql+asyncpg://video_bot:video_bot@postgres:5432/video_bot
# REDIS_URL=redis://redis:6379/0

# Optional. Use a local Telegram Bot API server for larger files.
# TELEGRAM_API_BASE=http://telegram-bot-api:8081
# TELEGRAM_API_IS_LOCAL=true
